{
  "build": {
    "distDir": "../",
    "devPath": "../",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "package": {
    "productName": "AetherForge",
    "version": "1.0.4"
  },
  "tauri": {
    "allowlist": {
      "all": true,
      "fs": {
        "all": true,
        "scope": ["$APP/**/*", "$USER/**/*"]
      },
      "path": {
        "all": true
      },
      "http": {
        "all": true,
        "request": true,
        "scope": ["https://*"]
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.aetherforge.desktop",
      "icon": []
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "AetherForge AI Game Engine",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ]
  }
}
